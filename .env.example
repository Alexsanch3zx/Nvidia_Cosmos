# Copy to `.env` next to app.py (never commit real `.env`).

REQUIRE_LOGIN=0
LOGIN_USERNAME=your_username
LOGIN_PASSWORD=your_password

# Hugging Face model id OR local folder with downloaded weights
COSMOS_MODEL=nvidia/Cosmos-Reason2-8b
COSMOS_MODEL_LABEL=Cosmos-Reason2-8B

# Ollama summary generation (required for app summary step)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
# OLLAMA_NUM_PREDICT=4096
